{
  "name": "@jomscode21/json-to-csv-lite",
  "version": "1.0.0",
  "description": "Fast, lightweight JSON-to-CSV converter for Node.js and CLI use",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "bin": {
    "json-to-csv-lite": "src/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "node src/try.js",
    "start": "node src/cli.js"
  },
  "keywords": [
    "json",
    "csv",
    "converter",
    "npm-package",
    "cli"
  ],
  "author": "JomsCode21",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JomsCode21/JSON-to-CSV-lite.git"
  },
  "bugs": {
    "url": "https://github.com/JomsCode21/JSON-to-CSV-lite/issues"
  },
  "homepage": "https://github.com/JomsCode21/JSON-to-CSV-lite#readme",
  "publishConfig": {
    "access": "public"
  }
}
